	<model_units/>
	<model>
		<variables>
			<stock name="Susceptible">
				<eqn>99999</eqn>
				<outflow>IRQ</outflow>
				<outflow>IR</outflow>
				<outflow>VR</outflow>
			</stock>
			<stock name="Infected\nQuarantine">
				<eqn>0</eqn>
				<inflow>IRQ</inflow>
				<outflow>RRQ</outflow>
			</stock>
			<stock name="Infected">
				<eqn>1</eqn>
				<inflow>IR</inflow>
				<outflow>RR</outflow>
			</stock>
			<stock name="Susceptible\nVaccinated">
				<eqn>0</eqn>
				<inflow>VR</inflow>
			</stock>
			<stock name="Recovered">
				<eqn>0</eqn>
				<inflow>RRQ</inflow>
				<inflow>RR</inflow>
			</stock>
			<flow name="IRQ">
				<eqn>Quarantine_Fraction*Lambda*Susceptible</eqn>
				<non_negative/>
			</flow>
			<flow name="IR">
				<eqn>(1-Quarantine_Fraction)*Lambda*Susceptible</eqn>
				<non_negative/>
			</flow>
			<flow name="VR">
				<eqn>Susceptible*Vaccination_Fraction</eqn>
				<non_negative/>
			</flow>
			<stock name="Vaccination\nFraction">
				<eqn>0</eqn>
				<inflow>CVF</inflow>
			</stock>
			<aux name="Quarantine\nFraction">
				<eqn>0</eqn>
			</aux>
			<aux name="R0">
				<eqn>2</eqn>
			</aux>
			<flow name="RRQ">
				<eqn>Infected_Quarantine/Recovery_Duration</eqn>
				<non_negative/>
			</flow>
			<flow name="RR">
				<eqn>Infected/Recovery_Duration</eqn>
				<non_negative/>
			</flow>
			<flow name="CVF">
				<eqn>Rollout_Fraction*(Maximum_Vaccination_Fraction-Vaccination_Fraction)</eqn>
				<non_negative/>
			</flow>
			<aux name="Maximum\nVaccination\nFraction">
				<eqn>0.05</eqn>
			</aux>
			<aux name="N">
				<eqn>Infected + Infected_Quarantine + Recovered + Susceptible + Susceptible_Vaccinated</eqn>
				<isee:summing/>
			</aux>
			<aux name="Transmission\nCoefficient">
				<eqn>R0/Recovery_Duration</eqn>
			</aux>
			<aux name="Lambda">
				<eqn>Transmission_Coefficient*(Infected+Transmission_Modifier*Infected_Quarantine)/N</eqn>
			</aux>
			<aux name="Transmission\nModifier">
				<eqn>0.5</eqn>
			</aux>
			<aux name="Rollout Fraction">
				<eqn>0.1</eqn>
			</aux>
			<aux name="Recovery\nDuration">
				<eqn>2</eqn>
			</aux>
			<aux name="Attack Rate">
				<eqn>Recovered/N</eqn>
			</aux>
		</variables>
