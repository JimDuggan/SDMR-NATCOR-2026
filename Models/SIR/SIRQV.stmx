	<isee:sensi_specs_list active_index="0">
		<isee:sensi_specs name="Sensitivity" method="latin_hypercube" runs="10000" seed="100">
			<isee:variable type="uniform" min="0" max="1" seed="12345" name="Rollout_Fraction" num_samples="5"/>
			<isee:variable type="uniform" min="0" max="1" name="Quarantine_Fraction" num_samples="5"/>
			<isee:variable type="uniform" min="0" max="1" name="Transmission_Modifier" num_samples="5"/>
			<isee:variable type="uniform" min="1.5" max="4" name="R0" num_samples="5"/>
		</isee:sensi_specs>
	</isee:sensi_specs_list>
